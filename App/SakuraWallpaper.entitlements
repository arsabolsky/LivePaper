<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- App entitlements: non-sandboxed so it can write to the extension container
     and call NSWorkspace for system desktop sync. -->
<plist version="1.0">
<dict>
    <!-- Security-scoped bookmarks let the app re-access user-selected video files
         across launches without showing a file picker every time. -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
    <!-- Development build marker for Apple Development (personal-team) signing.
         Matches Phosphene's Xcode-built app entitlements. -->
    <key>com.apple.security.get-task-allow</key>
    <true/>
</dict>
</plist>
